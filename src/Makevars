# Portable defaults only — R CMD check flags -O3/-march=native as
# non-portable.  The AVX2 kernels do NOT need special flags: on x86-64 they
# are compiled via per-function target attributes and enabled at runtime
# when the CPU supports AVX2+FMA (see src/cpu_features.cpp).  Optionally
# put  CXXFLAGS += -O3 -march=native -ffast-math  in ~/.R/Makevars for
# extra native tuning.
CXX_STD = CXX17
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS)
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS)
